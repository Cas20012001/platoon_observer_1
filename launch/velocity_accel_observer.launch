<launch>
    <!-- Robot number -->
    <arg name="car_number" default="3"/>

    <!-- Input mode:
         throttle_model = use teleop throttle and DART model to estimate acceleration
         desired_acc    = use /desired_acc_<car_number>
         acc_saturated  = use /acc_saturated_<car_number>
    -->
    <arg name="input_mode" default="throttle_model"/>

    <node pkg="platoon_observer"
          type="velocity_accel_observer.py"
          name="velocity_accel_observer_$(arg car_number)"
          output="screen">

        <param name="car_number" value="$(arg car_number)"/>

        <!-- Main robot data topic -->
        <param name="combined_topic" value="/sensors_and_input_$(arg car_number)"/>

        <!-- Optional acceleration-command topics for later -->
        <param name="desired_acc_topic" value="/desired_acc_$(arg car_number)"/>
        <param name="acc_saturated_topic" value="/acc_saturated_$(arg car_number)"/>

        <!-- Output topics -->
        <param name="state_estimate_topic" value="/state_estimate_$(arg car_number)"/>
        <param name="observer_input_topic" value="/observer_input_acc_$(arg car_number)"/>

        <!-- Select input source -->
        <param name="input_mode" value="$(arg input_mode)"/>

        <!-- /sensors_and_input layout -->
        <param name="velocity_index" value="6"/>
        <param name="acceleration_index" value="3"/>
        <param name="throttle_index" value="8"/>

        <!-- Sign/bias tuning -->
        <param name="velocity_sign" value="1.0"/>
        <param name="accel_sign" value="1.0"/>
        <param name="throttle_sign" value="1.0"/>
        <param name="imu_accel_bias" value="0.0"/>

        <!-- DART model -->
        <param name="mass" value="1.67"/>
        <param name="model_accel_scale" value="1.0"/>

        <!-- Observer sample time -->
        <param name="sample_time" value="0.1"/>

        <!-- Discrete observer matrices -->
        <param name="Ad_00" value="1.0000"/>
        <param name="Ad_01" value="0.0632"/>
        <param name="Ad_10" value="0.0000"/>
        <param name="Ad_11" value="0.3679"/>

        <param name="Bd_0" value="0.0368"/>
        <param name="Bd_1" value="0.6321"/>

        <param name="Ld_00" value="0.6321"/>
        <param name="Ld_01" value="0.0632"/>
        <param name="Ld_10" value="0.0000"/>
        <param name="Ld_11" value="0.2325"/>

        <!-- Initial estimate -->
        <param name="initial_velocity" value="0.0"/>
        <param name="initial_acceleration" value="0.0"/>

    </node>
</launch>
